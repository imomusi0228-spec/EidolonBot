generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int        @id @default(autoincrement())
  discord_id String     @unique
  username   String
  created_at   DateTime      @default(now())
  licenses     License[]
  downloads    Download[]
  UserFeatures    UserFeature[]
  Presets         Preset[]
  UserSetting     UserSetting?
  AIJobs          AIJob[]
  AnalyticsEvents AnalyticsEvent[]
  CreatedAssets   Asset[]       @relation("CreatorAssets")
}

model License {
  id          Int      @id @default(autoincrement())
  license_key String   @unique
  tier        String   @default("Free")
  status      String   @default("Active") // Active, Banned, Suspended, RateLimited
  activated   Boolean  @default(false)
  user_id     Int?
  user        User?    @relation(fields: [user_id], references: [id])
  machine_id  String?  // 現在紐付いているメイン機体（複数台対応は別途JSON化も可だが、一旦1枠ベースでロジック対応）
  swap_count  Int      @default(0)   // 短期間の切り替え検知用
  last_swap_at DateTime?
  created_at  DateTime @default(now())
}

model Download {
  id        Int      @id @default(autoincrement())
  user_id   Int
  user      User     @relation(fields: [user_id], references: [id])
  product   String
  timestamp DateTime @default(now())
}

model Feature {
  id           Int           @id @default(autoincrement())
  slug         String        @unique // e.g., "auto_repair"
  name         String
  description  String?
  UserFeatures UserFeature[]
}

model UserFeature {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id])
  feature_id Int
  feature    Feature  @relation(fields: [feature_id], references: [id])
  created_at DateTime @default(now())

  @@unique([user_id, feature_id])
}

model Preset {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id])
  name       String
  data       Json     // Store as JSON blob
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model UserSetting {
  id         Int      @id @default(autoincrement())
  user_id    Int      @unique
  user       User     @relation(fields: [user_id], references: [id])
  settings   Json
  updated_at DateTime @updatedAt
}

model AIJob {
  id         Int      @id @default(autoincrement())
  user_id    Int
  user       User     @relation(fields: [user_id], references: [id])
  type       String   // "repair", "blendshape", "expression"
  status     String   // "pending", "processing", "completed", "failed"
  input_data Json?
  result_url String?
  created_at DateTime @default(now())
  updated_at DateTime @updatedAt
}

model AnalyticsEvent {
  id         Int      @id @default(autoincrement())
  user_id    Int?
  user       User?    @relation(fields: [user_id], references: [id])
  event_name String
  properties Json?
  timestamp  DateTime @default(now())
}

model Asset {
  id           Int      @id @default(autoincrement())
  creator_id   Int
  creator      User     @relation("CreatorAssets", fields: [creator_id], references: [id])
  name         String
  description  String?
  download_url String
  created_at   DateTime @default(now())
}

model Version {
  id           Int      @id @default(autoincrement())
  tool_version String
  release_date DateTime @default(now())
  download_url String
}

model BoothOrder {
  id           Int      @id @default(autoincrement())
  order_id     String   @unique
  product_name String
  quantity     Int      @default(1)
  claimed      Boolean  @default(false)
  claimed_at   DateTime?
  created_at   DateTime @default(now())
}
